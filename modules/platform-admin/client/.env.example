# Admin Dashboard Client — Environment Variables
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control.
# -------------------------------------------------------------------------

# URL of the suite-shavi BFF (required).
# The client calls the BFF; the BFF proxies to the Bassan.os core API.
# Production value is set via Railway / CI secret management.
VITE_API_URL=https://<suite-shavi-bff-hostname>

# ---------------------------------------------------------------------------
# The variables below are for REFERENCE ONLY.
# They document the contract between the BFF and the core API / JWKS server.
# They are NOT read by the client bundle — set them in the BFF server env.
# ---------------------------------------------------------------------------

# S2S JWT for sandbox admin access (short-lived RS256, TTL 300s)
# Signed by admin-private.pem; verified via JWKS at ADMIN_JWKS_URL.
# SECURITY: Never hardcode or persist. Use gen-token.js for local dev only.
# BFF server env — NOT a VITE_ variable.
# ADMIN_JWT=<output-of-gen-token.js>

# JWKS URL for RS256 JWT verification (BFF server env — NOT a VITE_ variable).
# ADMIN_JWKS_URL=https://jwks-server-production.up.railway.app/.well-known/jwks.json

# Core API base URL (BFF server env — NOT a VITE_ variable).
# CORE_API_URL=https://<bassan-os-core-api-hostname>

# ---------------------------------------------------------------------------
# Legacy reference — direct-call pattern (NOT used by suite-shavi BFF client).
# Documented here for completeness because the earlier adminApi.ts file that
# was removed from BassanOs referenced these as VITE_ env vars.
# The authorised pattern is BFF-mediated (VITE_API_URL above).
# ---------------------------------------------------------------------------
# VITE_ADMIN_JWT=<short-lived-rs256-token>
# VITE_CORE_API_URL=https://<core-api-hostname>
